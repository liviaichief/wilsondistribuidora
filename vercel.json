{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_APPWRITE_ENDPOINT": "https://sfo.cloud.appwrite.io/v1",
    "VITE_APPWRITE_PROJECT_ID": "69ebf93f000372e879ff",
    "VITE_DATABASE_ID": "main_db",
    "VITE_COLLECTION_PRODUCTS": "products",
    "VITE_COLLECTION_BANNERS": "banners",
    "VITE_COLLECTION_ORDERS": "orders",
    "VITE_COLLECTION_PROFILES": "profiles",
    "VITE_APPWRITE_BUCKET_ID": "images_bucket",
    "VITE_COLLECTION_CAMPANHAS": "campanhas_comunicacao",
    "VITE_FUNC_SEND_CAMPANHA": "send-campanha"
  }
}
